{#  drdro shared GitHub release-notes template (same file in every drdro-* repo).

    Output matches python-semantic-release's default release notes, with one change:
    a FULL release folds in the commits of every prerelease made since the previous
    full release. Without this, a stable cut right after its betas publishes an
    empty release body (python-semantic-release#817).

    Hidden files in changelog.template_dir override ONLY the release notes;
    CHANGELOG.md keeps using the built-in default templates.


    ── vendored from psr's default macros.md.j2 (unchanged) ─────────────────────
#}{%  macro format_link(link, label)
%}{{    "[%s](%s)" | format(label, link)
}}{%  endmacro
%}{%  macro capitalize_first_letter_only(sentence)
%}{{    (sentence[0] | upper) ~ sentence[1:]
}}{%  endmacro
%}{%  macro commit_msg_links(commit)
%}{%    if commit.error is undefined
%}{%      set link_references = []
%}{%      set summary_line = capitalize_first_letter_only(commit.descriptions[0] | safe)
%}{%      if commit.linked_merge_request != ""
%}{%        set _ = link_references.append(
              format_link(
                commit.linked_merge_request | pull_request_url,
                commit.linked_merge_request
              )
            )
%}{%      endif
%}{%      set _ = link_references.append(
            format_link(
              commit.hexsha | commit_hash_url,
              "`%s`" | format(commit.short_hash)
            )
          )
%}{%      set formatted_links = ""
%}{%      if link_references | length > 0
%}{%        set formatted_links = " (%s)" | format(link_references | join(", "))
%}{%      endif
%}{{      summary_line ~ formatted_links
}}{%    endif
%}{%  endmacro
%}{%  macro format_commit_summary_line(commit)
%}{%    if commit.error is undefined
%}{%      set summary_line = commit_msg_links(commit)
%}{%      if commit.scope
%}{%        set summary_line = "**%s**: %s" | format(commit.scope, summary_line)
%}{%      endif
%}{{      summary_line
}}{%    else
%}{{      (commit.commit.message | string).split("\n", maxsplit=1)[0]
}}{%    endif
%}{%  endmacro
%}{%  macro format_attr_paragraphs(commit, attribute)
%}{%    set ns = namespace(full_description="")
%}{%    if commit.error is undefined
%}{%      for paragraph in commit | attr(attribute)
%}{%        if paragraph | trim | length > 0
%}{%          set ns.full_description = [
                ns.full_description,
                capitalize_first_letter_only(paragraph) | trim | safe,
              ] | join("\n\n")
%}{%        endif
%}{%      endfor
%}{%      set ns.full_description = ns.full_description | trim
%}{%      if commit.scope
%}{%        set ns.full_description = "**%s**: %s" | format(
              commit.scope, ns.full_description
            )
%}{%      endif
%}{%    endif
%}{{    ns.full_description
}}{%  endmacro
%}{%  macro order_commits_alphabetically_by_scope_and_attr(ns, attr)
%}{%    set ordered_commits = []
%}{%    set filtered_commits = ns.commits | rejectattr("error", "defined") | list
%}{%    for commit in filtered_commits | rejectattr("scope") | sort(attribute=attr)
%}{%      set _ = ordered_commits.append(commit)
%}{%    endfor
%}{%    for commit in filtered_commits | selectattr("scope") | sort(attribute=(['scope', attr] | join(",")))
%}{%      set _ = ordered_commits.append(commit)
%}{%    endfor
%}{%    set ns.commits = ordered_commits
%}{%  endmacro
%}{#

    ── release-notes body ───────────────────────────────────────────────────────

    Aggregation window: the release itself plus, for a full release, every
    immediately-preceding prerelease back to (not including) the previous full
    release. `releases` is ordered newest → oldest.
#}{%  set max_line_width = max_line_width | default(1000)
%}{%  set hanging_indent = hanging_indent | default(2)
%}{%  set license_name = license_name | default("", True)
%}{%  set releases = context.history.released.values() | list
%}{%  set curr_index = releases.index(release)
%}{%  set win = namespace(group=[release], prev_release=none)
%}{%  if not release.version.is_prerelease
%}{%    for rel in releases[curr_index + 1:]
%}{%      if win.prev_release is none
%}{%        if rel.version.is_prerelease
%}{%          set _ = win.group.append(rel)
%}{%        else
%}{%          set win.prev_release = rel
%}{%        endif
%}{%      endif
%}{%    endfor
%}{%  elif curr_index + 1 < releases | length
%}{%    set win.prev_release = releases[curr_index + 1]
%}{%  endif
%}{#
    # Heading + license line (same as psr's versioned_changes.md.j2)
#}{{  "## %s (%s)\n" | format(
        release.version.as_semver_tag(),
        release.tagged_date.strftime("%Y-%m-%d")
      )
}}{%  if license_name is defined and license_name
%}{{    "\n_This release is published under the %s License._\n" | format(license_name)
}}{%  endif
%}{#
#}{%  if mask_initial_release and win.prev_release is none
%}{#    # The window reaches the beginning of history: this is the first release
        # (or the stable graduation of the first prereleases) — keep psr's masking.
#}{{    "\n- Initial Release\n"
}}{%  else
%}{#    # Union of section names across the window, rendered like changes.md.j2
#}{%    set section_names = []
%}{%    for rel in win.group
%}{%      for type_ in rel["elements"].keys()
%}{%        if type_ != "unknown" and type_ not in section_names
%}{%          set _ = section_names.append(type_)
%}{%        endif
%}{%      endfor
%}{%    endfor
%}{#
#}{%    for type_ in section_names | sort
%}{%      set sec = namespace(commits=[])
%}{%      for rel in win.group
%}{%        for commit in rel["elements"].get(type_, [])
%}{%          set _ = sec.commits.append(commit)
%}{%        endfor
%}{%      endfor
%}{%      set _ = order_commits_alphabetically_by_scope_and_attr(sec, 'descriptions.0')
%}{%      set commit_descriptions = []
%}{%      for commit in sec.commits
%}{%        set description = "- %s" | format(format_commit_summary_line(commit))
%}{%        set _ = commit_descriptions.append(
              description | autofit_text_width(max_line_width, hanging_indent)
            )
%}{%      endfor
%}{%      if commit_descriptions | length > 0
%}{{        "\n### %s\n" | format(type_ | title)
}}{{        "\n%s\n" | format(commit_descriptions | unique | join("\n\n"))
}}{%      endif
%}{%    endfor
%}{#
        # Breaking changes & release notices across the whole window
#}{%    set all = namespace(commits=[])
%}{%    for rel in win.group
%}{%      for type_, commits in rel["elements"] | dictsort
%}{%        for commit in commits
%}{%          set _ = all.commits.append(commit)
%}{%        endfor
%}{%      endfor
%}{%    endfor
%}{#
#}{%    set brk = namespace(commits=(
          all.commits | rejectattr("error", "defined")
                      | selectattr("breaking_descriptions.0") | list
        ))
%}{%    if brk.commits | length > 0
%}{%      set _ = order_commits_alphabetically_by_scope_and_attr(brk, 'breaking_descriptions.0')
%}{%      set brking_descriptions = []
%}{%      for commit in brk.commits
%}{%        set full_description = "- %s" | format(
              format_attr_paragraphs(commit, 'breaking_descriptions').split("\n\n") | join("\n\n- ")
            )
%}{%        set _ = brking_descriptions.append(
              full_description | autofit_text_width(max_line_width, hanging_indent)
            )
%}{%      endfor
%}{{      "\n### Breaking Changes\n"
}}{{      "\n%s\n" | format(brking_descriptions | unique | join("\n\n"))
}}{%    endif
%}{#
#}{%    set notice = namespace(commits=(
          all.commits | rejectattr("error", "defined")
                      | selectattr("release_notices.0") | list
        ))
%}{%    if notice.commits | length > 0
%}{%      set _ = order_commits_alphabetically_by_scope_and_attr(notice, 'release_notices.0')
%}{%      set release_notices = []
%}{%      for commit in notice.commits
%}{%        set full_description = "- %s" | format(
              format_attr_paragraphs(commit, 'release_notices').split("\n\n") | join("\n\n- ")
            )
%}{%        set _ = release_notices.append(
              full_description | autofit_text_width(max_line_width, hanging_indent)
            )
%}{%      endfor
%}{{      "\n### Additional Release Information\n"
}}{{      "\n%s\n" | format(release_notices | unique | join("\n\n"))
}}{%    endif
%}{#
        # Detailed-changes compare link: full releases compare against the previous
        # FULL release (spanning the betas), prereleases against the previous tag.
#}{%    if 'compare_url' is filter and win.prev_release is not none
%}{%      set prev_version_tag = win.prev_release.version.as_tag()
%}{%      set new_version_tag = release.version.as_tag()
%}{%      set version_compare_url = prev_version_tag | compare_url(new_version_tag)
%}{%      set detailed_changes_link = '[{}...{}]({})'.format(
            prev_version_tag, new_version_tag, version_compare_url
          )
%}{{      "\n---\n"
}}{{      "\n**Detailed Changes**: %s" | format(detailed_changes_link)
}}{%    endif
%}{%  endif
%}
