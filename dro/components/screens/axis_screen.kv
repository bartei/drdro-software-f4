#: import StringItem dro.components.widgets.string_item
#: import NumberItem dro.components.widgets.number_item
#: import DropDownItem dro.components.widgets.dropdown_item
#: import BooleanItem dro.components.widgets.boolean_item
#: import TitleItem dro.components.widgets.title_item

<AxisScreen>:
  BoxLayout:
    orientation: "vertical"
    padding: 10
    ScreenHeader:
      text: "Axis: {}".format(root.axis.axis_name if root.axis else "?")

    ScrollView:
      do_scroll_x: False
      do_scroll_y: True
      GridLayout:
        id: grid_layout
        cols: 1
        spacing: 1
        size_hint_y: None
        height: self.minimum_height

        StringItem:
          name: "Axis Name"
          value: root.axis.axis_name if root.axis else "?"
          help_file: "axis_name.md"
          on_value: root.axis.axis_name = self.value
        BooleanItem:
          name: "Spindle Mode"
          value: root.axis.spindleMode if root.axis else False
          help_file: "spindle_mode.md"
          on_value: root.axis.spindleMode = self.value
        NumberItem:
          # Edited in the current display unit (stored in mm); hidden for spindle axes,
          # which have no linear in-position window.
          name: "In-Position Tolerance ({})".format(root.axis.position_unit if (root.axis and root.axis.position_unit) else "mm")
          value: round(float(root.axis.position_tolerance * app.formats.factor), 6) if root.axis else 0.05
          help_file: "axis_position_tolerance.md"
          on_value: root.axis.position_tolerance = float(self.value / app.formats.factor)
          height: 0 if (root.axis.spindleMode if root.axis else False) else 60
          opacity: 0 if (root.axis.spindleMode if root.axis else False) else 1
          disabled: root.axis.spindleMode if root.axis else False

        TitleItem:
          name: "Sync Ratio"
        NumberItem:
          name: "Sync Ratio Numerator"
          value: root.axis.syncRatioNum if root.axis else 360
          integer: True
          help_file: "sync_ratio.md"
          on_value: root.axis.syncRatioNum = int(self.value)
        NumberItem:
          name: "Sync Ratio Denominator"
          value: root.axis.syncRatioDen if root.axis else 100
          integer: True
          help_file: "sync_ratio.md"
          on_value: root.axis.syncRatioDen = int(self.value)

        TitleItem:
          name: "Transform Configuration"
        DropDownItem:
          name: "Transform Type"
          value: root.transform_type_label
          options: ["Identity", "Sum"]
          help_file: "transform_type.md"
          on_value: root.transform_type_label = self.value
          disabled: root.axis.spindleMode if root.axis else False

        DropDownItem:
          name: "Scale Input"
          options: root.input_0_options
          value: root.input_0
          help_file: "scale_input.md"
          on_value: root.input_0 = self.value

        DropDownItem:
          disabled: root.transform_type_label != "Sum" or (root.axis.spindleMode if root.axis else False)
          name: "Second Scale Input"
          options: root.input_1_options
          value: root.input_1
          help_file: "scale_input.md"
          on_value: root.input_1 = self.value

    BoxLayout:
      orientation: "horizontal"
      size_hint_y: None
      height: 60
      spacing: 10
      padding: [36, 0, 36, 10]
      Button:
        text: "Apply Transform"
        font_size: app.formats.font_size
        background_color: [0.2, 0.6, 0.2, 1]
        on_release: root.apply_transform()
      Button:
        text: "Remove Axis"
        font_size: app.formats.font_size
        background_color: [0.8, 0.2, 0.2, 1]
        on_release: root.remove_axis()
