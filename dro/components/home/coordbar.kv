#: import Factory kivy.factory.Factory
#: import Keypad dro.components.popups.keypad
#: import AutoSizeButton dro.components.widgets.auto_size_button
#: import PositioningAid dro.components.widgets.positioning_aid

<CoordBar>:
  orientation: "horizontal"
  size_hint_y: 1
  Button:
    width: 96
    size_hint_x: None
    text: root.axis.axis_name if root.axis else "?"
    font_size: min(self.height / 1.5, self.width/1.5)
    background_color: [0.2, 1, 0.2, 1] if (root.axis and root.axis.syncEnable) else [0.3, 0.3, 0.3, 1]
    on_release: root.toggle_sync()

  BoxLayout:
    orientation: "horizontal"
    BoxLayout:
      size_hint_x: 0.5
      orientation: "vertical"
      BoxLayout:
        orientation: "horizontal"
        size_hint_y: 0.6
        AutoSizeButton:
          background_color: (0, 0, 0, 1)
          id: pos_label
          font_name: app.formats.font_name
          max_font_size: min(self.height / 1.1, self.parent.width/5)
          font_style: "bold"
          color: app.formats.display_color
          text: root.axis.formattedPosition if root.axis else "--"
          text_size: self.size
          halign: 'right'
          valign: 'center'
          on_release: root.update_position()
        Label:
          size_hint_x: None
          width: self.texture_size[0] + 4
          font_name: app.formats.font_name
          font_size: pos_label.font_size / 4
          color: app.formats.display_color
          text: root.axis.position_unit if root.axis else ""
          valign: 'center'
      BoxLayout:
        # Speed row: positioning aid in-line on the LEFT, speed readout on the right.
        orientation: "horizontal"
        size_hint_y: 0.2 if (app.formats.show_speeds or (app.formats.show_positioning_aid and root.axis and not root.axis.spindleMode)) else 0
        PositioningAid:
          # Always holds the left flex space so the speed readout is right-aligned on every
          # row (spindle included); only drawn/interactive for a linear axis with the aid on.
          # Hiding via opacity (not zero width) also stops the height-derived dot painting at
          # a collapsed edge.
          size_hint_x: 1
          opacity: 1 if (app.formats.show_positioning_aid and root.axis and not root.axis.spindleMode) else 0
          disabled: not self.opacity
          active: root.axis.target_active if root.axis else False
          axis: root.axis
          # Aid math runs in mm so the physical scale is unit-independent: distanceToGo is in
          # display units, divide by factor back to mm; tolerance + range are stored in mm.
          value: (root.axis.distanceToGo / float(app.formats.factor)) if root.axis else 0
          tolerance: root.axis.position_tolerance if root.axis else 0.05
          span: app.formats.positioning_range
          bar_color: app.formats.display_color
          dot_color: app.formats.display_color
          at_target_color: app.formats.accept_color
        Label:
          # Speed value — content-width so it never steals the aid's space.
          size_hint_x: None
          width: (self.texture_size[0] + 4) if app.formats.show_speeds else 0
          opacity: 1 if app.formats.show_speeds else 0
          font_name: app.formats.font_name
          font_size: self.height / 1.5
          font_style: "bold"
          color: app.formats.display_color
          text: root.axis.formattedSpeed if root.axis else "--"
          valign: 'top'
        Label:
          size_hint_x: None
          width: (self.texture_size[0] + 4) if app.formats.show_speeds else 0
          opacity: 1 if app.formats.show_speeds else 0
          font_name: app.formats.font_name
          font_size: self.height / 1.5 / 4
          color: app.formats.display_color
          text: root.axis.speed_unit if root.axis else ""
          valign: 'top'

    BoxLayout:
      size_hint_x: None
      width: 80
      orientation: 'vertical'
      Label:
        text: "Num"
        font_size: self.height / 1.5
        size_hint_y: 0.3
        color: app.formats.display_color
        halign: 'center'
        valign: 'top'
      Button:
        size_hint_y: 0.7
        font_name: app.formats.font_name
        font_size: self.width / 3
        font_style: "bold"
        background_color: [0.3, 0.3, 0.3, 1]
        color: app.formats.display_color
        text: str(int(root.axis.syncRatioNum)) if root.axis else "--"
        text_size: self.size
        halign: 'center'
        valign: 'middle'
        on_release: Factory.Keypad(integer=True).show(root.axis, 'syncRatioNum') if root.axis else None

    BoxLayout:
      size_hint_x: None
      width: 80
      orientation: 'vertical'
      Label:
        text: "Den"
        font_size: self.height / 1.5
        size_hint_y: 0.3
        color: app.formats.display_color
        halign: 'center'
        valign: 'top'
      Button:
        size_hint_y: 0.7
        font_name: app.formats.font_name
        font_size: self.width / 3
        font_style: "bold"
        background_color: [0.3, 0.3, 0.3, 1]
        color: app.formats.display_color
        text: str(int(root.axis.syncRatioDen)) if root.axis else "--"
        text_size: self.size
        halign: 'center'
        valign: 'middle'
        on_release: Factory.Keypad(integer=True).show(root.axis, 'syncRatioDen') if root.axis else None

  Button:
    text: "Zero"
    font_size: 24
    font_style: "bold"
    background_color: [0.5, 0.5, 0.5, 1]
    width: self.height
    size_hint_x: None
    on_press: root.on_zero_press()
    on_release: root.on_zero_release()
